# ============================================
# Bug-Wise Backend - Environment Variables
# ============================================

# Groq API Key (FREE) — get yours at https://console.groq.com
OPENAI_API_KEY=gsk_your-groq-key-here

# Groq base URL
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Groq model (free)
OPENAI_MODEL=llama-3.3-70b-versatile

# MongoDB (use your Atlas connection string)
MONGO_URI=mongodb+srv://admin:YourPassword@bugwise.hwo6ogn.mongodb.net/bugwise?appName=bugwise

# JWT
JWT_SECRET=bugwise-local-dev-secret-2024
JWT_EXPIRES_IN=7d

# Server
PORT=5001
NODE_ENV=development